# SERVER
PORT=3000
APP_BASE_URL=http://localhost:3000
APP_NAME=creator-card-api

# JWT (not required for this assessment)
JWT_SECRET=
JWT_DEFAULT_EXPIRY=

# HASH (not required for this assessment)
HASH_SALT_ROUNDS=

# EMAIL (not required for this assessment)
RESEND_TOKEN=
RESEND_SENDER_ADDRESS=
ALLOW_ALL_EMAILS=
EMAIL_NOTIF_INTERVAL_MINS=
EMAIL_FALLBACK_SLACK_WEBHOOK=


# DB — required: MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/creator_cards?retryWrites=true&w=majority
MONGODB_URI=

# MOCK (leave empty for normal operation)
MOCK_AUTHORIZATION_HEADER=
MODEL_MOCK_SESSION=
USE_MOCK_MODEL=
ALLOW_MOCKED_HTTP_PROXY=


# LOGGER
PINO_LOG_LEVEL=info
SHOW_RAW_HEADERS=
LOG_APP_REQUEST=
CAN_LOG_ENDPOINT_INFORMATION=

# REDIS (optional — only needed if using background workers/queues)
REDIS_URL=
QUEUE_NAME=

# VALIDATOR
NO_SINGLE_ERRORS=
TOP_LEVEL_ERROR_MESSAGE=

# SECRET MANAGER (optional — leave USE_SECRETS_MANAGER empty for local/dev)
AWS_ACCESS_KEY_ID=
SECRETS_MANAGER_ID=
USE_SECRETS_MANAGER=
AWS_SECRET_ACCESS_KEY=
